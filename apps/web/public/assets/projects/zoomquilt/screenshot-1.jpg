	<script type="text/javascript">
	/* ZOOM */
		zoomquilt();
	/* UI */
		$('#zoomquilt').mousedown(function(){$('body').toggleClass('infovisible');
		$('#info .close').mousedown(function(){$('body').removeClass('infovisible');});
		$('body').removeClass('historyvisible');});
		$('.historyinner .close').mousedown(function(){$('body').removeClass('historyvisible');});
		$('.showhistory').mousedown(function(){$('body').toggleClass('historyvisible');});

	</script>
